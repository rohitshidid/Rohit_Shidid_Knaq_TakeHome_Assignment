# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust if needed:  cp .env.example .env
# `.env` is gitignored; `.env.example` is the tracked template.
# ---------------------------------------------------------------------------

# --- Database (Postgres, run via docker-compose) ---
POSTGRES_USER=knaq
POSTGRES_PASSWORD=knaq_dev_pw
POSTGRES_DB=knaq

# Connection string the API uses.
# host = 'localhost' for local dev against the docker DB,
# host = 'db'        when the API itself runs inside docker-compose.
DATABASE_URL=postgresql://knaq:knaq_dev_pw@localhost:5432/knaq?schema=public

# --- API ---
API_PORT=8000

# --- Web (Next.js — NEXT_PUBLIC_ vars are exposed to the browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# Bearer token for the "logged-in" user; seeded in Phase 1.2.
NEXT_PUBLIC_API_TOKEN=tok_alice_brookfield
