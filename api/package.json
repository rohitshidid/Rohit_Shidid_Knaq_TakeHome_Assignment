{
  "name": "knaq-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Knaq backend — ingests IoT messages, exposes the triage REST API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "seed": "tsx prisma/seed.ts",
    "ingest": "tsx src/ingest/index.ts",
    "test": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "luxon": "^3.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
